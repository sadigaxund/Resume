# Whitelist approach: ignore all, then allow specific
*

# Allow descending into directories
!*/

# Allow source + output
!*.tex
!*.pdf

# Allow scripts + repo config
!*.sh
!scripts/*.sh
!.gitignore
!icons/*
!fonts/*.ttf
!.latexmkrc
!README.md
!preview.png
!server.py
!.github/workflows/*.yml

# Re-ignore build artifacts even if matched above
*.aux
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.xdv
*.bbl
*.blg
*.toc

.latexmkrc

tmp/
_cache/
