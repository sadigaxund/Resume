# Whitelist approach: ignore all, then allow specific
*

# Allow descending into directories
!*/

# Allow source + output
!*.tex
!*.pdf

# Allow scripts + repo config
!*.sh
!scripts/*.sh
!.gitignore
!template/icons/*
!template/fonts/*.ttf
!.latexmkrc
!README.md
!TODO.md
!app/server.py
!app/requirements.txt
!tex-packages.txt
!.github/workflows/*.yml

# Re-ignore build artifacts even if matched above
*.aux
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.xdv
*.bbl
*.blg
*.toc

.latexmkrc

tmp/
_cache/
